<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ title or "Tech Event Tracker" }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; max-width: 760px; margin: 2rem auto; padding: 0 1rem; line-height: 1.55; color: #1a1a1a; }
  a { color: #0a58ca; }
  h1 { margin-top: 0; }
  h2 { margin-top: 2rem; border-bottom: 1px solid #eee; padding-bottom: 0.25rem; }
  h3 { margin-top: 1.5rem; margin-bottom: 0.25rem; }
  nav.site { margin-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; flex-wrap: wrap; }
  nav.site a { text-decoration: none; }
  nav.site .nav-links a + a { margin-left: 1rem; }
  p.tagline { margin: 0 0 1rem 0; padding-bottom: 1rem; border-bottom: 1px solid #eee; color: #555; font-size: 0.95rem; }
  nav.tabs { display: flex; gap: 0; margin: 0 0 1.5rem 0; border-bottom: 1px solid #ddd; }
  nav.tabs a { display: inline-block; padding: 0.5rem 1rem; text-decoration: none; color: #555; border-bottom: 2px solid transparent; margin-bottom: -1px; font-size: 0.95rem; }
  nav.tabs a:hover { color: #0a58ca; }
  nav.tabs a.active { color: #1a1a1a; border-bottom-color: #0a58ca; font-weight: 600; }
  ul.event-list { list-style: none; padding: 0; }
  ul.event-list li { margin: 0 0 1.4rem 0; padding-bottom: 1rem; border-bottom: 1px solid #f0f0f0; }
  ul.event-list li:last-child { border-bottom: none; }
  .event-title { font-size: 1.1rem; font-weight: 600; }
  .event-meta { color: #666; font-size: 0.9rem; margin: 0.15rem 0 0.4rem 0; }
  .event-desc { margin: 0.3rem 0 0.5rem 0; }
  .event-links a { margin-right: 0.75rem; font-size: 0.9rem; }
  footer { margin-top: 4rem; padding-top: 1rem; border-top: 1px solid #eee; color: #666; font-size: 0.9rem; }
  footer p { margin: 0.25rem 0; }
  article :is(p, li) { word-wrap: break-word; overflow-wrap: break-word; }
</style>
</head>
<body>
<nav class="site">
  <a href="{{ '/' | absUrl }}"><strong>Tech Event Tracker</strong></a>
  <span class="nav-links">
    <a href="{{ '/about/' | absUrl }}">About</a>
  </span>
</nav>
<p class="tagline">On-site technology events &mdash; soonest first.</p>
<nav class="tabs" aria-label="Region">
  <a href="{{ '/' | absUrl }}"{% if pageType == "netherlands" %} class="active" aria-current="page"{% endif %}>Netherlands</a>
  <a href="{{ '/europe/' | absUrl }}"{% if pageType == "europe" %} class="active" aria-current="page"{% endif %}>Europe</a>
</nav>
{{ content | safe }}
<footer>
  <p>Curated with AI assistance. Always confirm dates and tickets on the official event website before booking travel.</p>
  <p><a href="{{ '/about/' | absUrl }}">About</a></p>
</footer>
</body>
</html>
